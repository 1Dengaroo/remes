# Required — Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required — Site URL for SEO (sitemap, robots, OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required — Claude API for query parsing and summary generation
ANTHROPIC_API_KEY=

# Required — Apollo API for company discovery and people search
# Sign up at https://www.apollo.io/
APOLLO_API_KEY=

# Optional — Gmail OAuth for sending emails
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-domain.com/api/gmail/callback
